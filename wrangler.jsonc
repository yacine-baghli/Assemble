{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "assemble",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
  // Runtime secrets are injected via `wrangler secret put <NAME>` or the CF dashboard.
  // NEXT_PUBLIC_* values are baked at build time (see .dev.vars / CI env).
}
