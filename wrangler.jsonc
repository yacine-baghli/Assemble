{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "assemble-voice-agent-demo",
  "main": "./worker/index.js",
  "compatibility_date": "2026-07-11",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
