# Copy to `secrets.local.env`, paste your real values, then run:
#   bash scripts/push-secrets.sh
# It routes each value to the right place:
#   • NEXT_PUBLIC_* → .env.local (build-time, safe)
#   • everything else → Convex (`npx convex env set`, where the actions run)
# `secrets.local.env` is gitignored. Never commit real keys.

# ── Heavy secrets → Convex ───────────────────────────────────────────
OPENAI_API_KEY=
LINKUP_API_KEY=
ELEVENLABS_API_KEY=
RESEND_API_KEY=
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=

# ── Optional tuning → Convex ─────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
ELEVENLABS_VOICE_ID=
RESEND_FROM=
DODO_MODE=test
DODO_PRODUCT_ID=

# ── Public (build-time) → .env.local ─────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
